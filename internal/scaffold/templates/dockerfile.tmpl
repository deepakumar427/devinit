{{- if eq .Language "go" -}}
FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o {{.ProjectName}} .

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /root/
COPY --from=builder /app/{{.ProjectName}} .
EXPOSE 8080
CMD ["./{{.ProjectName}}"]
{{- else if eq .Language "node" -}}
FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production
COPY . .
EXPOSE 3000
CMD ["node", "index.js"]
{{- else if eq .Language "python" -}}
FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY . .
EXPOSE 8000
CMD ["python", "main.py"]
{{- else -}}
FROM ubuntu:22.04
WORKDIR /app
COPY . .
{{- end }}